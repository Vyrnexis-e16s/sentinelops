{
  "name": "Credential dumping (LSASS access)",
  "description": "Access to LSASS process memory by a non-system process.",
  "query_dsl": {
    "all_of": [
      {"field": "source", "op": "eq", "value": "sysmon"},
      {"field": "parsed.event_id", "op": "eq", "value": 10},
      {"field": "parsed.target_image", "op": "regex", "value": "(?i)\\\\lsass\\.exe$"}
    ],
    "none_of": [
      {"field": "parsed.source_image", "op": "regex",
       "value": "(?i)\\\\(wininit|services|csrss|smss|lsaiso)\\.exe$"}
    ],
    "score": 9.0,
    "severity": "critical"
  },
  "attack_technique_ids": ["T1003"]
}
