# Copy to .env and edit. Never commit .env.

# --- Core ---
APP_NAME=SentinelOps
APP_ENV=development
SECRET_KEY=change-me-to-a-64-char-random-hex-string
LOG_LEVEL=INFO

# --- Database ---
POSTGRES_USER=sentinel
POSTGRES_PASSWORD=devpassword
POSTGRES_DB=sentinelops
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://sentinel:devpassword@db:5432/sentinelops

# --- Redis / Celery ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# --- Auth ---
JWT_ALGORITHM=HS256
# Access token lifetime (minutes). 480 = 8h — reduce in production if required.
JWT_EXPIRE_MINUTES=480
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=SentinelOps
WEBAUTHN_ORIGIN=http://localhost:3000

# --- Vault ---
VAULT_MASTER_KEY=change-me-64-char-hex-root-key-for-kek-wrapping
VAULT_STORAGE_PATH=/var/lib/sentinelops/vault

# --- Recon ---
RECON_MAX_CONCURRENCY=50
# I/O to scanned hosts (NVD uses NVD_REQUEST_TIMEOUT below).
RECON_TIMEOUT_SECONDS=15
# Optional: limit scan targets. Comma/space/semicolon separated suffixes, IPs, or CIDRs. Empty = any (dev only).
# RECON_TARGET_ALLOWLIST=scanme.nmap.org,10.0.0.0/8,192.168.0.0/16
NVD_API_BASE=https://services.nvd.nist.gov/rest/json/cves/2.0
# https://nvd.nist.gov/developers/request-an-api-key — better rate limits (recommended for CVE jobs)
# NVD_API_KEY=
# CVE lookups can be slow; NVD 2.0 may take tens of seconds without a key.
NVD_REQUEST_TIMEOUT=90

# --- IDS ---
IDS_MODEL_PATH=/app/ml/artifacts/ids_rf.joblib

# --- VAPT (optional): OpenAI or OpenAI-compatible (Ollama, vLLM) for /api/v1/vapt/llm/summarize
# Full install & config guide: docs/LOCAL_LLM.md
# Leave unconfigured to use surface + briefs only (LLM returns 503 with setup text).
# Cloud: set OPENAI_API_KEY and SENTINELOPS_LLM_BASE_URL=https://api.openai.com/v1
# Local (Ollama): run:  bash scripts/setup-local-llm.sh  OR  .\\scripts\\setup-local-llm.ps1
# Then merge .env.llm.local.generated into .env. Example for host + Ollama on same machine:
# SENTINELOPS_LLM_OLLAMA=1
# OPENAI_API_KEY=ollama
# SENTINELOPS_LLM_BASE_URL=http://127.0.0.1:11434/v1
# Two-step (recommended locally): small model drafts facts, SENTINELOPS_LLM_MODEL writes the brief
# SENTINELOPS_LLM_DRAFT_MODEL=qwen2.5:7b
# SENTINELOPS_LLM_MODEL=llama3.1:8b
# SENTINELOPS_LLM_CASCADE=1
# OPENAI_API_KEY=
# SENTINELOPS_LLM_MODEL=gpt-4o-mini
# SENTINELOPS_LLM_BASE_URL=https://api.openai.com/v1

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000
# WebSocket base (no /alerts path; the UI appends /ws/alerts?token=…)
NEXT_PUBLIC_WS_URL=ws://localhost:8000
# Optional: paste a JWT for UI-only dev without localStorage (do not use in production)
# NEXT_PUBLIC_DEV_TOKEN=

# --- Metrics ---
EXPOSE_PROMETHEUS=true

# Optional integration values reserved for roadmap features (see docs/ROADMAP.md)
# KAFKA_BOOTSTRAP=
# OIDC_ISSUER=
# S3_VAULT_ENDPOINT=
# NEO4J_URI=
# HSM_PKCS11_LIB=
NEXT_PUBLIC_DEFAULT_THEME=tactical
